# Model to use (provider prefix must match a key below)
PROMPT_WRITER_MODEL=openai/gpt-4.1-mini
OPENAI_API_KEY=your-api-key

# Required for fallback model (always in retry chain)
OPENCODE_API_KEY=your-api-key

# Other providers (uncomment model + matching key)
# PROMPT_WRITER_MODEL=anthropic/claude-sonnet-4-6
# ANTHROPIC_API_KEY=your-api-key
# PROMPT_WRITER_MODEL=google/gemini-2.5-flash
# GOOGLE_GENERATIVE_AI_API_KEY=your-api-key